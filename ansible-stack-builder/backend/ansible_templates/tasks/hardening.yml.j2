<# tasks/hardening.yml — Généré par Ansible Stack Builder #>
# ============================================================================
# Hardening — Durcissement SSH, paramètres kernel, protocoles réseau
# ============================================================================

# --- SSH ---
- name: Deploy hardened sshd_config
  template:
    src: templates/sshd_config.j2
    dest: /etc/ssh/sshd_config
    owner: root
    group: root
    mode: '0600'
    validate: '/usr/sbin/sshd -t -f %s'
  notify: Restart SSH

- name: Ensure SSH is enabled
  systemd:
    name: sshd
    state: started
    enabled: yes

# --- Kernel ---
- name: Configure kernel security parameters (sysctl)
  copy:
    content: |
      # --- Anti-spoofing ---
      net.ipv4.conf.all.rp_filter = 1
      net.ipv4.conf.default.rp_filter = 1

      # --- Anti-ICMP ---
      net.ipv4.icmp_echo_ignore_broadcasts = 1

      # --- Routage ---
      net.ipv4.conf.all.accept_source_route = 0
      net.ipv6.conf.all.accept_source_route = 0
      net.ipv4.conf.all.send_redirects = 0
      net.ipv4.conf.default.send_redirects = 0

      # --- Anti-SYN flood ---
      net.ipv4.tcp_syncookies = 1
      net.ipv4.tcp_max_syn_backlog = 2048
      net.ipv4.tcp_synack_retries = 2

      # --- Logging ---
      net.ipv4.conf.all.log_martians = 1

      # --- Anti-redirect ---
      net.ipv4.conf.all.accept_redirects = 0
      net.ipv6.conf.all.accept_redirects = 0
      net.ipv4.conf.default.accept_redirects = 0
      net.ipv6.conf.default.accept_redirects = 0

      # --- ASLR (Address Space Layout Randomization) ---
      kernel.randomize_va_space = 2

      # --- Désactiver le routage IPv4/IPv6 ---
<% if enable_docker %>
      # ip_forward = 1 requis par Docker pour le réseau bridge
      net.ipv4.ip_forward = 1
<% else %>
      net.ipv4.ip_forward = 0
<% endif %>
      net.ipv6.conf.all.forwarding = 0

      # --- Protection contre les core dumps ---
      fs.suid_dumpable = 0
    dest: /etc/sysctl.d/90-hardening.conf
    mode: '0644'
  notify: Apply sysctl

# --- Désactivation des core dumps ---
- name: Disable core dumps via limits
  copy:
    content: |
      * hard core 0
      * soft core 0
    dest: /etc/security/limits.d/disable-coredumps.conf
    mode: '0644'

# --- Protocoles réseau inutiles ---
- name: Disable unused network protocols
  copy:
    content: |
      install dccp /bin/true
      install sctp /bin/true
      install rds /bin/true
      install tipc /bin/true
    dest: /etc/modprobe.d/disable-protocols.conf
    mode: '0644'
