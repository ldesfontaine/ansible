<# tasks/crowdsec-bouncer.yml — Généré par Ansible Stack Builder #>
# ============================================================================
# CrowdSec Firewall Bouncer — Installé sur l'HÔTE (pas dans Docker)
# ============================================================================

- name: Add CrowdSec repository
  shell: "curl -s https://install.crowdsec.net/install.sh | sh"
  args:
    creates: /etc/apt/sources.list.d/crowdsec_crowdsec.list

- name: Update apt cache for CrowdSec
  apt:
    update_cache: yes

- name: Install CrowdSec Firewall Bouncer (nftables)
  apt:
    name: crowdsec-firewall-bouncer-nftables
    state: present

- name: Wait for CrowdSec LAPI to be available
  wait_for:
    host: 127.0.0.1
    port: 8080
    timeout: 60
    delay: 5

- name: Deploy bouncer configuration
  template:
    src: templates/crowdsec-firewall-bouncer.yaml.j2
    dest: /etc/crowdsec/bouncers/crowdsec-firewall-bouncer.yaml
    owner: root
    group: root
    mode: '0600'
  notify: Restart Bouncer

- name: Enable and start CrowdSec Firewall Bouncer
  systemd:
    name: crowdsec-firewall-bouncer
    state: started
    enabled: yes
