<# crowdsec-firewall-bouncer.yaml.j2 — Généré par Ansible Stack Builder #>
# ============================================================================
# CrowdSec Firewall Bouncer — Configuration nftables
# Managed by Ansible
# ============================================================================

mode: nftables
pid_dir: /var/run/
update_frequency: {{ bouncer_update_frequency }}
daemonize: true

log_mode: file
log_dir: /var/log/
log_level: {{ bouncer_log_level }}
log_compression: true
log_max_size: 100
log_max_backups: 3
log_max_age: 30

api_url: http://127.0.0.1:8080/
api_key: {{ crowdsec_lapi_key }}
insecure_skip_verify: false

disable_ipv6: false
deny_action: {{ bouncer_deny_action }}
deny_log: true
deny_log_prefix: "crowdsec: "

supported_decisions_types:
  - ban

nftables:
  ipv4:
    enabled: true
    set-only: false
    table: crowdsec
    chain: crowdsec-chain
    priority: -10
  ipv6:
    enabled: true
    set-only: false
    table: crowdsec6
    chain: crowdsec6-chain
